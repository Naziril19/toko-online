<%- include('partials/header') %>

<div class="row justify-content-center align-items-center py-5" style="min-height: 75vh;">
  <div class="col-md-6 col-lg-5">
    <div class="card glass-card p-4 border-0">
      <div class="card-body">
        <h2 class="fw-bold text-center text-primary mb-4">Lupa Password</h2>
        <p class="text-secondary text-center mb-4">Masukkan email Anda dan kami akan mengirimkan tautan untuk mengatur ulang password Anda.</p>

        <% if (error_msg) { %>
          <div class="alert alert-danger d-flex align-items-center rounded-3 border-0 py-3 mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-5"></i>
            <div><%= error_msg %></div>
          </div>
        <% } %>

        <% if (success_msg) { %>
          <div class="alert alert-success d-flex align-items-center rounded-3 border-0 py-3 mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i>
            <div><%= success_msg %></div>
          </div>
        <% } %>

        <form action="/auth/forgot-password" method="POST">
          <div class="mb-4">
            <label for="email" class="form-label fw-semibold">Alamat Email</label>
            <div class="input-group">
              <span class="input-group-text bg-transparent border-end-0 text-secondary"><i class="bi bi-envelope"></i></span>
              <input type="email" class="form-control border-start-0" id="email" name="email" placeholder="johndoe@email.com" required>
            </div>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 mb-3">Kirim Tautan Reset</button>
        </form>

        <div class="text-center mt-4">
          <a href="/auth/login" class="text-primary fw-semibold text-decoration-none">
            <i class="bi bi-arrow-left me-1"></i> Kembali ke Halaman Masuk
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
