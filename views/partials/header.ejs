<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' | Toko Online Modern' : 'Toko Online Modern' %></title>
  
  <!-- Meta SEO -->
  <meta name="description" content="Toko Online Modern menjual berbagai produk elektronik dan aksesoris berkualitas premium dengan harga terjangkau.">
  <meta name="keywords" content="elektronik, aksesoris, laptop, handphone, toko online, e-commerce">
  
  <!-- Google Fonts & Bootstrap 5 + Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- SweetAlert2 -->
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
  
  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <!-- Loading Animation Overlay -->
  <div id="loading-overlay">
    <div class="spinner-border text-light" style="width: 3rem; height: 3rem;" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  </div>

  <!-- Modern Navigation Bar -->
  <nav class="navbar navbar-expand-lg glass-nav py-3">
    <div class="container">
      <a class="navbar-brand d-flex align-items-center fw-bold text-primary fs-4" href="/">
        <i class="bi bi-cpu-fill me-2"></i>
        <span>ElectroTech</span>
      </a>
      
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      
      <div class="collapse navbar-collapse" id="navbarNav">
        <!-- Navigation Links -->
        <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-center">
          <li class="nav-item">
            <a class="nav-link fw-medium" href="/">Home</a>
          </li>
          <li class="nav-item">
            <a class="nav-link fw-medium" href="/products">Katalog</a>
          </li>
          <% if (typeof user !== 'undefined' && user && user.role === 'customer') { %>
            <li class="nav-item">
              <a class="nav-link fw-medium" href="/orders">
                <i class="bi bi-receipt me-1"></i> Pesanan Saya
              </a>
            </li>
          <% } %>
          <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
            <li class="nav-item">
              <a class="nav-link fw-bold text-danger" href="/admin/dashboard">
                <i class="bi bi-speedometer2 me-1"></i> Admin Panel
              </a>
            </li>
          <% } %>
        </ul>

        <!-- Search Bar -->
        <form class="d-flex me-lg-3 my-2 my-lg-0 position-relative" action="/products" method="GET" style="width: 100%; max-width: 300px;">
          <input class="form-control pe-5 rounded-pill" type="search" placeholder="Cari elektronik..." aria-label="Search" name="search" id="search-input" value="<%= typeof searchVal !== 'undefined' ? searchVal : '' %>">
          <button class="btn btn-link position-absolute end-0 top-50 translate-middle-y text-muted me-2" type="submit" style="padding: 0;">
            <i class="bi bi-search" style="font-size: 1.1rem;"></i>
          </button>
        </form>

        <!-- Right Buttons -->
        <div class="d-flex align-items-center gap-3">
          <!-- Dark Mode Toggle -->
          <button id="theme-toggle" class="theme-toggle-btn" title="Ganti Tema">
            <i class="bi bi-moon-fill"></i>
          </button>

          <!-- Shopping Cart Badge -->
          <a href="/cart" class="btn btn-link position-relative text-secondary p-2" title="Keranjang Belanja">
            <i class="bi bi-cart3 fs-4 text-primary"></i>
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger cart-badge <%= (typeof cartCount !== 'undefined' && cartCount > 0) ? '' : 'd-none' %>">
              <%= typeof cartCount !== 'undefined' ? cartCount : 0 %>
            </span>
          </a>

          <!-- User Authenticated Menu -->
          <% if (typeof user !== 'undefined' && user) { %>
            <div class="dropdown">
              <button class="btn btn-outline-primary dropdown-toggle d-flex align-items-center gap-2 rounded-pill px-3" type="button" id="userMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-person-circle"></i>
                <span class="d-none d-md-inline"><%= (user.full_name || '').split(' ')[0] || 'Akun' %></span>
              </button>
              <ul class="dropdown-menu dropdown-menu-end border-0 shadow-lg mt-2 rounded-4" aria-labelledby="userMenuButton">
                <li class="px-3 py-2 border-bottom">
                  <div class="fw-bold"><%= user.full_name %></div>
                  <small class="text-muted"><%= user.email %></small>
                </li>
                <li><a class="dropdown-item py-2" href="/orders"><i class="bi bi-receipt me-2"></i> Riwayat Pesanan</a></li>
                <% if (user.role === 'admin') { %>
                  <li><a class="dropdown-item py-2 text-danger" href="/admin/dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard Admin</a></li>
                <% } %>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item py-2 text-danger" href="/auth/logout" onclick="event.preventDefault(); document.getElementById('logout-form').submit();">
                    <i class="bi bi-box-arrow-right me-2"></i> Keluar
                  </a>
                </li>
              </ul>
            </div>
            <!-- Logout Form (POST required for clean logout session handling) -->
            <form id="logout-form" action="/auth/logout" method="POST" style="display: none;"></form>
          <% } else { %>
            <a href="/auth/login" class="btn btn-outline-primary rounded-pill px-4">Masuk</a>
            <a href="/auth/register" class="btn btn-primary rounded-pill px-4">Daftar</a>
          <% } %>
        </div>
      </div>
    </div>
  </nav>

  <main class="py-4">
    <div class="container">
