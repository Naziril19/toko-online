<%- include('partials/header') %>

<div class="row justify-content-center align-items-center py-5" style="min-height: 70vh;">
  <div class="col-md-7 text-center">
    <div class="card glass-card border-0 p-5 shadow-lg">
      <div class="mb-4">
        <i class="bi bi-exclamation-octagon text-danger" style="font-size: 5rem;"></i>
      </div>
      
      <h1 class="fw-bold text-danger mb-2">
        <%= typeof error !== 'undefined' && error.status ? error.status : '500' %>
      </h1>
      
      <h3 class="fw-bold mb-3"><%= title %></h3>
      
      <p class="text-secondary mb-4 fs-5 leading-relaxed">
        <%= message %>
      </p>

      <% if (typeof error !== 'undefined' && error.stack && process.env.NODE_ENV !== 'production') { %>
        <div class="text-start mt-4 bg-dark text-light p-3 rounded-3 overflow-auto" style="max-height: 250px; font-family: monospace; font-size: 0.8rem;">
          <pre class="mb-0"><code><%= error.stack %></code></pre>
        </div>
      <% } %>

      <div class="mt-4">
        <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold">
          <i class="bi bi-house-door me-2"></i> Kembali ke Halaman Utama
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
