<%- include('../partials/header') %>

<div class="row g-4">
  <!-- Sidebar -->
  <div class="col-lg-3">
    <%- include('../partials/admin-sidebar') %>
  </div>

  <!-- Main Content -->
  <div class="col-lg-9">
    <div class="card glass-card border-0 p-4">
      <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3 mb-4">
        <div>
          <h4 class="fw-bold text-primary mb-1">Manajemen Kategori</h4>
          <p class="text-secondary mb-0">Kelola kategori produk yang tersedia di toko online Anda.</p>
        </div>
        <button class="btn btn-primary rounded-pill px-4" data-bs-toggle="modal" data-bs-target="#addCategoryModal">
          <i class="bi bi-plus-circle me-2"></i>Tambah Kategori
        </button>
      </div>

      <% if (categories.length === 0) { %>
        <p class="text-secondary text-center py-5">Belum ada kategori. Silakan tambahkan kategori baru.</p>
      <% } else { %>
        <div class="table-responsive">
          <table class="table align-middle">
            <thead>
              <tr>
                <th scope="col">Nama Kategori</th>
                <th scope="col">Deskripsi</th>
                <th scope="col" class="text-center">Tanggal Dibuat</th>
                <th scope="col" class="text-center" style="width: 150px;">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <% categories.forEach(cat => { %>
                <tr>
                  <td class="fw-bold text-secondary"><%= cat.name %></td>
                  <td class="small text-secondary"><%= cat.description || '-' %></td>
                  <td class="text-center small text-secondary">
                    <%= new Date(cat.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </td>
                  <td class="text-center">
                    <div class="d-flex justify-content-center gap-2">
                      <!-- Edit Button -->
                      <button class="btn btn-outline-primary btn-sm rounded-circle p-2" 
                              data-bs-toggle="modal" 
                              data-bs-target="#editCategoryModal" 
                              onclick="populateEditModal('<%= cat.id %>', '<%= cat.name %>', '<%= cat.description %>')" 
                              title="Edit Kategori">
                        <i class="bi bi-pencil"></i>
                      </button>
                      
                      <!-- Delete Button -->
                      <button class="btn btn-outline-danger btn-sm rounded-circle p-2" 
                              onclick="deleteCategory('<%= cat.id %>')" 
                              title="Hapus Kategori">
                        <i class="bi bi-trash"></i>
                      </button>

                      <form id="delete-form-<%= cat.id %>" action="/admin/categories/delete/<%= cat.id %>" method="POST" style="display:none;"></form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Modal: Add Category -->
<div class="modal fade" id="addCategoryModal" tabindex="-1" aria-labelledby="addCategoryLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border-0">
      <div class="modal-header border-bottom">
        <h5 class="modal-title fw-bold text-primary" id="addCategoryLabel">Tambah Kategori Baru</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/admin/categories/add" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label for="name" class="form-label fw-semibold">Nama Kategori</label>
            <input type="text" class="form-control" id="name" name="name" required placeholder="Aksesoris, Smartphone, dll">
          </div>
          <div class="mb-3">
            <label for="description" class="form-label fw-semibold">Deskripsi</label>
            <textarea class="form-control" id="description" name="description" rows="3" placeholder="Keterangan singkat kategori..."></textarea>
          </div>
        </div>
        <div class="modal-footer border-top">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary rounded-pill px-4">Simpan Kategori</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal: Edit Category -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-labelledby="editCategoryLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content glass-card border-0">
      <div class="modal-header border-bottom">
        <h5 class="modal-title fw-bold text-primary" id="editCategoryLabel">Edit Kategori</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editCategoryForm" method="POST">
        <div class="modal-body">
          <div class="mb-3">
            <label for="edit-name" class="form-label fw-semibold">Nama Kategori</label>
            <input type="text" class="form-control" id="edit-name" name="name" required>
          </div>
          <div class="mb-3">
            <label for="edit-description" class="form-label fw-semibold">Deskripsi</label>
            <textarea class="form-control" id="edit-description" name="description" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer border-top">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Batal</button>
          <button type="submit" class="btn btn-primary rounded-pill px-4">Perbarui</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  function populateEditModal(id, name, description) {
    document.getElementById('editCategoryForm').action = `/admin/categories/edit/${id}`;
    document.getElementById('edit-name').value = name;
    document.getElementById('edit-description').value = description;
  }

  function deleteCategory(id) {
    confirmDelete(
      'Hapus Kategori?',
      'Menghapus kategori dapat menyebabkan produk yang terhubung menjadi tanpa kategori!',
      () => {
        showLoading();
        document.getElementById(`delete-form-${id}`).submit();
      }
    );
  }
</script>

<%- include('../partials/footer') %>
