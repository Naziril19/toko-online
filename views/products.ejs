<%- include('partials/header') %>

<% 
// Helper to format currency
const formatRupiah = (num) => {
  return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', minimumFractionDigits: 0 }).format(num);
};
%>

<div class="row">
  <!-- Title & Description -->
  <div class="col-12 mb-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/" class="text-decoration-none text-primary">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">Katalog Produk</li>
      </ol>
    </nav>
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
      <div>
        <h1 class="fw-bold mb-1">Katalog Produk</h1>
        <p class="text-secondary mb-0">Temukan perangkat elektronik dan aksesoris berteknologi tinggi.</p>
      </div>
      <div class="text-secondary fw-semibold">
        Menampilkan <span class="text-primary"><%= products.length %></span> dari <span class="text-primary"><%= count || 0 %></span> produk
      </div>
    </div>
  </div>

  <!-- Filters Sidebar -->
  <div class="col-lg-3 mb-4">
    <div class="card glass-card border-0 p-4 sticky-lg-top" style="top: 100px; z-index: 10;">
      <h5 class="fw-bold mb-3 d-flex align-items-center justify-content-between">
        <span><i class="bi bi-filter-left text-primary me-2"></i>Filter</span>
        <a href="/products" class="small text-decoration-none text-muted" style="font-size: 0.8rem;">Riset Filter</a>
      </h5>
      
      <form action="/products" method="GET">
        <!-- Preserve Search Query -->
        <% if (query.search) { %>
          <input type="hidden" name="search" value="<%= query.search %>">
        <% } %>

        <!-- Category Filter -->
        <div class="mb-4">
          <label class="form-label fw-semibold text-primary mb-2">Kategori</label>
          <div class="d-flex flex-column gap-2" style="max-height: 200px; overflow-y: auto;">
            <div class="form-check">
              <input class="form-check-input" type="radio" name="category" id="cat-all" value="" <%= !query.category ? 'checked' : '' %> onchange="this.form.submit()">
              <label class="form-check-label text-secondary" for="cat-all">Semua Kategori</label>
            </div>
            <% categories.forEach(cat => { %>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="category" id="cat-<%= cat.id %>" value="<%= cat.id %>" <%= query.category === cat.id ? 'checked' : '' %> onchange="this.form.submit()">
                <label class="form-check-label text-secondary" for="cat-<%= cat.id %>"><%= cat.name %></label>
              </div>
            <% }) %>
          </div>
        </div>

        <!-- Price Range Filter -->
        <div class="mb-4">
          <label class="form-label fw-semibold text-primary mb-2">Rentang Harga</label>
          <div class="row g-2 align-items-center">
            <div class="col">
              <input type="number" class="form-control form-control-sm" name="min_price" placeholder="Min" value="<%= query.min_price || '' %>">
            </div>
            <div class="col-auto text-secondary text-center small">-</div>
            <div class="col">
              <input type="number" class="form-control form-control-sm" name="max_price" placeholder="Max" value="<%= query.max_price || '' %>">
            </div>
          </div>
        </div>

        <!-- Sorting Filter -->
        <div class="mb-4">
          <label class="form-label fw-semibold text-primary mb-2">Urutkan</label>
          <select class="form-select form-select-sm" name="sort" onchange="this.form.submit()">
            <option value="newest" <%= query.sort === 'newest' || !query.sort ? 'selected' : '' %>>Terbaru</option>
            <option value="price_asc" <%= query.sort === 'price_asc' ? 'selected' : '' %>>Harga Terendah</option>
            <option value="price_desc" <%= query.sort === 'price_desc' ? 'selected' : '' %>>Harga Tertinggi</option>
            <option value="stock" <%= query.sort === 'stock' ? 'selected' : '' %>>Stok Terbanyak</option>
          </select>
        </div>

        <button type="submit" class="btn btn-primary btn-sm w-100 py-2 rounded-3">Terapkan Filter</button>
      </form>
    </div>
  </div>

  <!-- Products Catalog List -->
  <div class="col-lg-9">
    <!-- Active Filters Display -->
    <% if (query.search || query.category || query.min_price || query.max_price) { %>
      <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
        <span class="text-secondary small">Filter Aktif:</span>
        <% if (query.search) { %>
          <span class="badge bg-primary px-3 py-2 rounded-pill d-flex align-items-center gap-2">
            Cari: "<%= query.search %>"
            <a href="/products?<%= new URLSearchParams({...query, search: ''}).toString() %>" class="text-white text-decoration-none"><i class="bi bi-x"></i></a>
          </span>
        <% } %>
        <% if (query.category) { 
          const currentCat = categories.find(c => c.id === query.category);
          if (currentCat) { %>
            <span class="badge bg-primary px-3 py-2 rounded-pill d-flex align-items-center gap-2">
              Kategori: <%= currentCat.name %>
              <a href="/products?<%= new URLSearchParams({...query, category: ''}).toString() %>" class="text-white text-decoration-none"><i class="bi bi-x"></i></a>
            </span>
        <% } } %>
        <% if (query.min_price || query.max_price) { %>
          <span class="badge bg-primary px-3 py-2 rounded-pill d-flex align-items-center gap-2">
            Harga: <%= query.min_price ? formatRupiah(query.min_price) : '0' %> - <%= query.max_price ? formatRupiah(query.max_price) : 'Max' %>
            <a href="/products?<%= new URLSearchParams({...query, min_price: '', max_price: ''}).toString() %>" class="text-white text-decoration-none"><i class="bi bi-x"></i></a>
          </span>
        <% } %>
      </div>
    <% } %>

    <!-- Empty State -->
    <% if (products.length === 0) { %>
      <div class="card glass-card border-0 p-5 text-center my-4">
        <i class="bi bi-search text-muted" style="font-size: 4rem;"></i>
        <h4 class="fw-bold mt-3">Produk Tidak Ditemukan</h4>
        <p class="text-secondary">Coba ubah kata kunci pencarian Anda atau reset filter yang sedang aktif.</p>
        <div class="mt-2">
          <a href="/products" class="btn btn-primary rounded-pill px-4">Lihat Semua Produk</a>
        </div>
      </div>
    <% } else { %>
      <!-- Product Grid -->
      <div class="row g-4">
        <% products.forEach(product => { %>
          <div class="col-md-6 col-xl-4">
            <div class="card glass-card product-card">
              <div class="product-image-wrapper">
                <% if (product.stock === 0) { %>
                  <span class="badge bg-dark text-white position-absolute top-0 end-0 m-3 z-3">Habis</span>
                <% } else if (product.stock < 5) { %>
                  <span class="badge bg-warning text-dark position-absolute top-0 end-0 m-3 z-3">Stok Terbatas</span>
                <% } %>
                <img src="<%= product.image_url || 'https://images.unsplash.com/photo-1546868871-7041f2a55e12?q=80&w=600' %>" alt="<%= product.name %>">
              </div>
              <div class="card-body d-flex flex-column p-4">
                <span class="text-muted small fw-bold text-uppercase mb-1"><%= product.categories?.name || 'Elektronik' %></span>
                <h5 class="card-title fw-bold mb-2">
                  <a href="/products/<%= product.id %>" class="text-decoration-none text-primary hover-accent"><%= product.name %></a>
                </h5>
                <p class="card-text text-secondary small flex-grow-1"><%= product.description ? product.description.substring(0, 80) + '...' : 'Tidak ada deskripsi.' %></p>
                <div class="d-flex align-items-center gap-1 text-warning mb-3">
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <span class="text-secondary small ms-1">(5.0)</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                  <span class="fs-5 fw-bold text-primary"><%= formatRupiah(product.price) %></span>
                  <% if (product.stock > 0) { %>
                    <button class="btn btn-primary btn-sm rounded-3 add-to-cart-btn px-3" onclick="addToCart('<%= product.id %>', 1)" title="Tambah ke Keranjang">
                      <i class="bi bi-cart-plus fs-6"></i>
                    </button>
                  <% } else { %>
                    <button class="btn btn-secondary btn-sm rounded-3 px-3" disabled>
                      Habis
                    </button>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
        <nav class="mt-5 d-flex justify-content-center">
          <ul class="pagination">
            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
              <a class="page-link rounded-start-3" href="/products?<%= new URLSearchParams({...query, page: currentPage - 1}).toString() %>">
                <i class="bi bi-chevron-left"></i>
              </a>
            </li>
            <% for(let i=1; i<=totalPages; i++) { %>
              <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                <a class="page-link" href="/products?<%= new URLSearchParams({...query, page: i}).toString() %>"><%= i %></a>
              </li>
            <% } %>
            <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
              <a class="page-link rounded-end-3" href="/products?<%= new URLSearchParams({...query, page: currentPage + 1}).toString() %>">
                <i class="bi bi-chevron-right"></i>
              </a>
            </li>
          </ul>
        </nav>
      <% } %>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
